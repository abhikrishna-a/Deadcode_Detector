{
  "manifest_version": 3,
  "name": "GhostCode Dead Code Detector",
  "version": "1.0.0",
  "description": "Detect dead code in your browser-dev JavaScript/TypeScript files via the GhostCode analyzer.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:5173/*", "http://localhost:8002/*", "http://localhost:8003/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GhostCode",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
